{
  "name": "comment-overlay",
  "version": "4.0.0",
  "description": "Reusable comment overlay renderer engine.",
  "repository": {
    "url": "https://github.com/roflsunriz/comment-overlay"
  },
  "packageManager": "bun@1.3.8",
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/comment-overlay.cjs.js",
  "module": "dist/comment-overlay.es.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/comment-overlay.es.js",
      "require": "./dist/comment-overlay.cjs.js"
    }
  },
  "files": [
    "src",
    "dist",
    "DOCUMENTATION.md"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "dev": "vite",
    "build": "bun run clean && bun run typegen && vite build && bun scripts/sync-overlay-tests.mjs && bun run build:overlay-tests",
    "build:overlay-tests": "tsc --project tsconfig.overlay-tests.json",
    "serve": "bunx serve overlay-tests",
    "type-check": "tsc --project tsconfig.build.json --noEmit",
    "typegen": "tsc --project tsconfig.build.json",
    "lint": "eslint src --ext .ts",
    "preview": "vite preview",
    "nico:trace": "bun scripts/nico-trace.mjs",
    "nico:rdp-trace": "bun scripts/nico-rdp-trace.mjs",
    "nico:report": "bun scripts/nico-report.mjs",
    "nico:overlay-trace": "bun scripts/nico-overlay-trace.mjs",
    "nico:fetch-comments": "bun scripts/nico-fetch-comments.mjs",
    "nico:strict-score": "node scripts/nico-strict-score.mjs",
    "nico:internal-score": "node scripts/nico-internal-score.mjs",
    "nico:teacher-vs-teacher": "node scripts/nico-teacher-vs-teacher.mjs",
    "nico:blackbox-probe": "node scripts/nico-blackbox-probe-cdp.mjs",
    "nico:blackbox-lanes": "node scripts/nico-blackbox-lane-extract.mjs",
    "nico:probe-score": "node scripts/nico-probe-score.mjs",
    "nico:probe-overlay-capture": "node scripts/nico-probe-overlay-capture.mjs"
  },
  "keywords": [
    "comment",
    "overlay",
    "renderer"
  ],
  "author": "",
  "license": "MIT",
  "type": "module",
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@typescript-eslint/eslint-plugin": "^8.48.1",
    "@typescript-eslint/parser": "^8.48.1",
    "chrome-remote-interface": "^0.34.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^16.5.0",
    "prettier": "^3.7.3",
    "rimraf": "^6.1.2",
    "typescript": "^5.9.3",
    "vite": "^7.2.6"
  },
  "overrides": {
    "vite": {
      "rollup": "npm:@rollup/wasm-node@4.52.5"
    }
  }
}
