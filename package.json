{
  "name": "comment-overlay",
  "version": "4.1.3",
  "description": "Reusable comment overlay renderer engine.",
  "repository": {
    "url": "https://github.com/roflsunriz/comment-overlay"
  },
  "packageManager": "bun@1.3.8",
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/comment-overlay.cjs.js",
  "module": "dist/comment-overlay.es.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/comment-overlay.es.js",
      "require": "./dist/comment-overlay.cjs.js"
    }
  },
  "files": [
    "src",
    "dist",
    "DOCUMENTATION.md"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "dev": "vite",
    "build": "bun run clean && bun run typegen && vite build && bun scripts/sync-overlay-tests.mjs && bun run build:overlay-tests",
    "build:overlay-tests": "bun run generate:overlay-tests && tsc --project tsconfig.overlay-tests.json",
    "generate:overlay-tests": "bun scripts/generate-overlay-test-cases.mjs",
    "serve": "bun run build:overlay-tests && bunx serve overlay-tests",
    "test": "bun test src/comment/static-width-fit.test.ts src/comment/nico-scroll.test.ts src/comment/nico-timing.test.ts src/renderer/lanes-activation.test.ts research/tools/tests/fixed-ca-holdout.test.ts && node --test research/tools/tests/*.test.mjs",
    "type-check": "tsc --project tsconfig.build.json --noEmit",
    "typegen": "tsc --project tsconfig.build.json",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write research CHANGELOG.md how-to-update.md package.json",
    "preview": "vite preview",
    "nico:trace": "bun scripts/nico-trace.mjs",
    "nico:rdp-trace": "bun scripts/nico-rdp-trace.mjs",
    "nico:report": "bun scripts/nico-report.mjs",
    "nico:overlay-trace": "bun scripts/nico-overlay-trace.mjs",
    "nico:fetch-comments": "bun scripts/nico-fetch-comments.mjs",
    "nico:strict-score": "node scripts/nico-strict-score.mjs",
    "nico:internal-score": "node scripts/nico-internal-score.mjs",
    "nico:teacher-vs-teacher": "node scripts/nico-teacher-vs-teacher.mjs",
    "nico:blackbox-probe": "node scripts/nico-blackbox-probe-cdp.mjs",
    "nico:blackbox-lanes": "node scripts/nico-blackbox-lane-extract.mjs",
    "nico:probe-score": "node scripts/nico-probe-score.mjs",
    "nico:probe-overlay-capture": "node scripts/nico-probe-overlay-capture.mjs",
    "research:nico:capture": "node research/tools/capture-session.mjs",
    "research:nico:replay": "node research/tools/replay-session.mjs",
    "research:nico:analyze": "node research/tools/analyze-canvas-trace.mjs",
    "research:nico:lane-probe": "node research/tools/run-lane-pair-sweep.mjs",
    "research:nico:fixed-matrix": "node research/tools/run-fixed-comment-matrix.mjs",
    "research:nico:final-phase-analyze": "node research/tools/analyze-final-phase-equivalence.mjs",
    "research:nico:final-phase": "node research/tools/run-final-phase-equivalence.mjs",
    "research:nico:supplement": "node research/tools/supplement-static-resource.mjs",
    "research:test": "node --test research/tools/tests/*.test.mjs"
  },
  "keywords": [
    "comment",
    "overlay",
    "renderer"
  ],
  "author": "",
  "license": "MIT",
  "type": "module",
  "devDependencies": {
    "@types/node": "^25.9.5",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "chrome-remote-interface": "^0.34.0",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^16.5.0",
    "prettier": "^3.9.5",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "vite": "^7.3.6"
  },
  "overrides": {
    "esbuild": "0.28.1",
    "vite": {
      "rollup": "npm:@rollup/wasm-node@4.52.5"
    }
  }
}
