{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noImplicitAny": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "skipLibCheck": true,
    "outDir": "overlay-tests/build",
    "rootDir": "overlay-tests/src",
    "sourceMap": true
  },
  "include": ["overlay-tests/src/**/*.ts"],
  "exclude": ["overlay-tests/src/**/*.test.ts"]
}
